# Port the server listens on (binds 0.0.0.0)
PORT=3000

# Shared service-to-service API key, required via X-API-Key header on /v1/ocr
API_KEY=

# Local persistent volume path for uploaded images
STORAGE_PATH=./src/storage

# Number of days uploaded images are retained before the daily cleanup job deletes them
RETENTION_DAYS=7

# Max accepted upload size, in megabytes
MAX_FILE_SIZE_MB=10

# Optional: cookie string passed to chrome-lens-ocr's headers.cookie,
# useful if Google starts blocking/rate-limiting the server IP
LENS_COOKIE=

# Optional: proxy URL passed to chrome-lens-ocr's fetchOptions.dispatcher
LENS_PROXY_URL=
