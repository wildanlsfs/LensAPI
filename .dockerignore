# Local storage test artifacts — the app creates this directory itself,
# but don't bake any locally-generated uploads into the image. Keep
# src/fixtures/ (needed at runtime by GET /health/lens) out of this rule.
src/storage/*
!src/storage/.gitkeep

*.md
!README.md

